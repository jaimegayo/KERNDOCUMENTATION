<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/kern_background_watermark"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_question_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="NIVEL DE GIMNASIO"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:fontFamily="@font/montserrat_bold"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/ll_options_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tv_question_title">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_option_1"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#EB6F26"
            app:cardCornerRadius="15dp"
            app:cardElevation="8dp"
            app:strokeColor="@color/white"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_option_title_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRINCIPIANTE"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:fontFamily="@font/montserrat_bold"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_option_subtitle_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&lt; 6 MESES ENTRENANDO"
                    android:fontFamily="@font/montserrat_bold"
                    android:textStyle="bold"
                    android:textColor="#F0F0F0"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_option_2"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#311E60"
            app:cardCornerRadius="15dp"
            app:strokeColor="@color/white"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_option_title_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INTERMEDIO"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:fontFamily="@font/montserrat_bold"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_option_subtitle_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(6 MESES - 2 AÑOS) ENTRENANDO"
                    android:fontFamily="@font/montserrat_bold"
                    android:textStyle="bold"
                    android:textColor="#F0F0F0"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_option_3"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            app:cardBackgroundColor="#6D4A25"
            app:cardCornerRadius="15dp"
            app:strokeColor="@color/white"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_option_title_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AVANZADO"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:fontFamily="@font/montserrat_bold"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_option_subtitle_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ 2 AÑOS ENTRENANDO"
                    android:fontFamily="@font/montserrat_bold"
                    android:textStyle="bold"
                    android:textColor="#F0F0F0"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <Button
        android:id="@+id/btn_next"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SIGUIENTE"
        android:fontFamily="@font/montserrat_bold"
        android:textStyle="bold"
        android:backgroundTint="#E53935"
        android:paddingHorizontal="30dp"
        app:cornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>