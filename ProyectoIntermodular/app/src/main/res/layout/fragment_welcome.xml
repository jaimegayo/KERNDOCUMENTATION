<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    tools:context=".ui.WelcomeFragment">

    <ImageView
        android:id="@+id/iv_background_logo"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:alpha="0.2"
        android:scaleType="centerInside"
        android:src="@drawable/kern_background_watermark"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_logo_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="40dp"
        android:paddingVertical="10dp"
        android:src="@drawable/kern_logo_full"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="0dp" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="20dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@+id/btn_empezar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_logo_top">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¡Hola! Bienvenido a KERN"
                android:fontFamily="@font/poppins"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:fontFamily="@font/poppins"
                android:lineSpacingExtra="5dp"
                android:text="Estoy aquí para acompañarte en cada entrenamiento y ayudarte a crecer paso a paso.\nRegistra tus ejercicios, sigue tu progreso y descubre cómo los pequeños esfuerzos diarios se convierten en grandes resultados.\n\nNo importa si hoy entrenas ligero o desafías tus límites, lo importante es que sigas avanzando.\nCada serie, cada repetición y cada día cuenta. Además, recibirás mensajes motivacionales que te recordarán que estás en el camino correcto y que tu constancia vale más que cualquier atajo.\n\n¡Vamos! Tu mejor versión empieza hoy, y KERN estará contigo en cada paso del camino."
                android:textColor="#CCCCCC"
                android:textSize="16sp" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btn_empezar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:backgroundTint="#F27A30"
        android:paddingHorizontal="40dp"
        android:paddingVertical="12dp"
        android:text="EMPEZAR"
        android:fontFamily="@font/montserrat_bold"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:cornerRadius="25dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>