<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/backgroundworkouts"
    android:padding="12dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardTimer"
        android:layout_width="0dp"
        android:layout_height="80dp"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="12dp"
        app:layout_constraintHorizontal_weight="1.2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/cardStats">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/clocks"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvSessionTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="0h 00m 00s"
                android:textColor="#EA632E"
                android:textSize="14sp"
                android:fontFamily="@font/montserrat_bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardStats"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="8dp"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="12dp"
        app:layout_constraintHorizontal_weight="1.8"
        app:layout_constraintEnd_toStartOf="@+id/layoutActionButtons"
        app:layout_constraintStart_toEndOf="@+id/cardTimer"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Volumen"
                    android:fontFamily="@font/montserrat_extrabold"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvTotalVolume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 kg"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/montserrat_bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Series"
                    android:fontFamily="@font/montserrat_extrabold"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvTotalSets"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/montserrat_bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/layoutActionButtons"
        android:layout_width="wrap_content"
        android:layout_height="80dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_rounded_actions"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnRestTimer"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_timer"
            app:tint="#EA632E" />

        <View
            android:layout_width="20dp"
            android:layout_height="1dp"
            android:layout_marginVertical="4dp"
            android:background="#FFFFFF" />

        <LinearLayout
            android:id="@+id/btnStepCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_footsteps"
                app:tint="#FF5722" />
            <TextView
                android:id="@+id/tvStepCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#F0673B"
                android:textSize="12sp"
                android:fontFamily="@font/poppins"

                android:layout_marginStart="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvActiveExercises"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toTopOf="@+id/layoutBottomActions"
        app:layout_constraintTop_toBottomOf="@id/cardTimer" />

    <LinearLayout
        android:id="@+id/layoutBottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelWorkout"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="20dp"
            android:text="Cancelar"
            android:textSize="12sp"
            android:textColor="#F44336"
            android:fontFamily="@font/montserrat_bold"
            app:strokeColor="#F44336" />

        <Button
            android:id="@+id/btnFinishWorkout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:backgroundTint="#EA632E"
            android:text="Terminar Entrenamiento"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/montserrat_bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>