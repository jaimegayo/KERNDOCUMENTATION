<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.WorkoutFragment"
    android:background="@drawable/kern_background_watermark">

    <TextView
        android:id="@+id/tvBackgroundTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ENTRENAMIENTO"
        android:textColor="#1A1A1A"
        android:textSize="46sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="-10dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#121212"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvBackgroundTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnNuevaRutina"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_gradient_orange"
                    android:text="Nueva Rutina"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/montserrat_bold"
                    android:paddingStart="11dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRutinaPredeterminada"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_gradient_purple"
                    android:text="Rutinas\nPredeterminadas"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="@font/montserrat_bold"
                    android:paddingStart="12dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp" />
                    <TextView
                        android:layout_width="220dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chat_bubble"
                        android:padding="12dp"
                        android:text="&quot;NO NECESITAS DARLO TODO HOY. SOLO DAR UN POCO MÁS QUE LA SEMANA PASADA.&quot;"
                        android:textColor="#888888"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp" />
                    <TextView
                        android:layout_width="220dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chat_bubble"
                        android:padding="12dp"
                        android:text="RESPECTIVO MENSAJE MOTIVADOR"
                        android:textColor="#888888"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layoutTitleMisRutinas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/cardHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp">

        <TextView
            android:id="@+id/tvMisRutinasCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MIS RUTINAS (0)"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_bold" />

        <View
            android:layout_width="120dp"
            android:layout_height="3dp"
            android:background="#FFFFFF"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMisRutinas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTitleMisRutinas"
        tools:listitem="@layout/item_rutina_card" />

    <LinearLayout
        android:id="@+id/layoutEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTitleMisRutinas">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@android:drawable/ic_menu_add"
            android:alpha="0.3"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aún no tienes rutinas"
            android:textColor="#555555"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pulsa 'Nueva Rutina' para empezar"
            android:textColor="#444444"
            android:textSize="11sp"
            android:fontFamily="@font/montserrat_bold"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>